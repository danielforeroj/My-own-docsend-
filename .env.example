# Mode
# true/1/on/yes enables demo mode (admin routes won't be hard-blocked by middleware)
NEXT_PUBLIC_DEMO_MODE=false

# Supabase (required for connected mode)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (local/dev/prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (optional for lead notifications in connected mode)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=DocSend MVP <noreply@yourdomain.com>
LEAD_NOTIFICATION_EMAIL=ops@yourdomain.com
